# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ─── MongoDB Atlas ────────────────────────────────────────────────────────────
# Use the +srv string from Atlas → Connect → Drivers
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/Orderly?retryWrites=true&w=majority

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_THIS_64_CHAR_RANDOM_STRING
JWT_EXPIRES_IN=7d

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list (no spaces) of allowed frontend origins
FRONTEND_URL=https://yourapp.vercel.app

# ─── Admin seed ───────────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=ChangeThisStrongPassword123!

# ─── Email (Gmail SMTP for Forgot Password) ───────────────────────────────────
# 1. Enable 2-Step Verification on Gmail
# 2. Go to: https://myaccount.google.com/apppasswords
# 3. Create an App Password for "Mail" → copy the 16-char code
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=xxxx_xxxx_xxxx_xxxx
EMAIL_FROM=Orderly <your_gmail@gmail.com>
